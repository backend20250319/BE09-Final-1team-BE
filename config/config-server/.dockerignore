# =======================================================
# 보안 관련 파일 (Secrets)
# =======================================================
/.env*
/.pem
/.rsa
/.key
/.p12
/.pfx
/.crt
/.cer
/.der
/.jks
/.keystore
**/secrets/
**/credentials/
**/config/secrets/
**/private/
**/keys/

# =======================================================
# Git 및 버전 관리 (Version Control)
# =======================================================
/.git
/.gitignore
/.gitattributes

# =======================================================
# IDE 및 편집기 설정 (IDE & Editor)
# =======================================================
/.vscode/
/.idea/
# Vim swap files
*.swp
*.swo
*~

# =======================================================
# 빌드 결과물 (Build Artifacts)
# - 멀티 스테이지 빌드를 사용하므로, 로컬 빌드 결과는 모두 제외합니다.
# =======================================================
/.gradle
**/build/

# =======================================================
# 로그 파일 (Logs)
# =======================================================
*.log