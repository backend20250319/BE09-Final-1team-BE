# =================
# Java Service .dockerignore (보안 강화)
# =================

# 🔒 보안 파일들 (절대 업로드 금지)
**/.env*
**/.pem
**/.rsa
**/.key
**/.p12
**/.pfx
**/.crt
**/.cer
**/.der
**/.jks
**/.keystore
**/secrets/
**/credentials/
**/config/secrets/
**/private/
**/keys/

# Git 관련
**/.git
**/.gitignore
**/.gitattributes

# IDE 관련
**/.vscode/
**/.idea/
**/*.swp
**/*.swo
**/*~

# Java 관련
**/build/
**/target/
**/*.jar
**/*.war
**/*.ear
**/*.class
**/.gradle/
**/gradle/
**/bin/
**/out/
**/.settings/
**/.project
**/.classpath
**/.factorypath
**/.metadata/
**/.recommenders/

# 로그 파일
**/*.log
**/logs/
**/log/

# 문서
**/README.md
**/*.md
**/docs/
**/documentation/

# 테스트 관련
**/src/test/
**/test/
**/tests/
**/*Test.java
**/*Tests.java
**/test_*/

# 임시 파일
**/*.tmp
**/*.temp
**/*.bak
**/*.backup

# OS 관련
**/.DS_Store
**/Thumbs.db
**/desktop.ini

# Docker 관련
**/Dockerfile*
**/docker-compose*.yml
**/.dockerignore

# Python 관련 (중복 제거 스크립트용)
**/duplicate_detector/__pycache__/
**/duplicate_detector/*.pyc
**/duplicate_detector/*.pyo
**/duplicate_detector/.pytest_cache/

# 기타
**/node_modules/
**/.cache/
